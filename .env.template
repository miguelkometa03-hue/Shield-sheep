# Shield-Sheep Environment Configuration Template
# Copy this to .env and fill in your actual values
# NEVER commit .env to git (it's in .gitignore)

# ========================================
# AI AGENTS CONFIGURATION
# ========================================

# Jules.ia Integration
# Get from: https://console.jules.ia/api-keys
JULES_API_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxx
JULES_MODEL=julius-large
JULES_ENDPOINT=https://api.jules.ia/v1

# Qwen Code Integration  
# Get from: https://huggingface.co/settings/tokens
QWEN_API_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxx
QWEN_MODEL=qwen-coder-latest
QWEN_REPOSITORY=miguelkometa03-hue/Shield-sheep

# ========================================
# CLOUDINARY CONFIGURATION
# ========================================

# Get from: https://cloudinary.com/console/settings/api-keys
CLOUDINARY_CLOUD_NAME=xxxxx
CLOUDINARY_API_KEY=xxxxxxxxxxxxxxxxxxxxx
CLOUDINARY_API_SECRET=xxxxxxxxxxxxxxxxxxxxx
CLOUDINARY_URL_SECURE=true

# Cloudinary URLs will be generated as:
# https://res.cloudinary.com/{CLOUD_NAME}/image/upload/f_auto,q_auto:best,w_auto/{PUBLIC_ID}

# ========================================
# GITHUB INTEGRATION
# ========================================

# Get from: https://github.com/settings/tokens/new
# Required scopes: repo, workflow
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxx
GITHUB_OWNER=miguelkometa03-hue
GITHUB_REPO=Shield-sheep

# ========================================
# SECURITY & MONITORING
# ========================================

# Security Contact Email
SECURITY_EMAIL=admin@shield-sheep.io

# Error Tracking (Sentry)
# Get from: https://sentry.io/settings/account/api/auth-tokens/
SENTRY_DSN=https://xxxxx@sentry.io/xxxxx
SENTRY_ENVIRONMENT=production

# Analytics
# Get from: Google Analytics / Mixpanel / Plausible
ANALYTICS_KEY=xxxxxxxxxxxxxxxxxxxxx

# ========================================
# SERVER CONFIGURATION
# ========================================

# Server Port
PORT=8000

# Environment
NODE_ENV=development

# Debug Mode (comma-separated: agent,cloudinary,security,performance)
DEBUG=

# ========================================
# PROJECT SETTINGS
# ========================================

# Project Name (for reports)
PROJECT_NAME=Shield-Sheep

# Report Output Location
REPORTS_DIR=./reports

# Logs Directory
LOGS_DIR=./logs

# ========================================
# AGENT SCHEDULE
# ========================================

# Cron schedule for automated checks
# Format: "0 0 * * *" (min hour day month weekday)

# Daily security audit (3 AM UTC)
SECURITY_AUDIT_SCHEDULE=0 3 * * *

# Daily performance check (9 AM UTC)  
PERFORMANCE_CHECK_SCHEDULE=0 9 * * *

# Weekly Cloudinary optimization (Sunday 2 AM UTC)
CLOUDINARY_OPTIMIZE_SCHEDULE=0 2 * * 0

# ========================================
# FEATURE FLAGS
# ========================================

# Enable/disable agents
ENABLE_UI_REVIEW=true
ENABLE_CODE_ANALYSIS=true
ENABLE_PERFORMANCE_OPT=true
ENABLE_SECURITY_AUDIT=true
ENABLE_MEDIA_MANAGER=true
ENABLE_TEST_GENERATOR=true
ENABLE_DOCS_GENERATOR=true

# Enable/disable integrations
USE_JULES=true
USE_QWEN=true
USE_CLOUDINARY=true
USE_GITHUB=true

# ========================================
# PERFORMANCE THRESHOLDS
# ========================================

# Core Web Vitals Targets
LCP_TARGET=2500                # milliseconds
FID_TARGET=100                 # milliseconds
CLS_TARGET=0.1                 # unitless

# Code Quality Targets
CODE_COMPLEXITY_MAX=10         # cyclomatic complexity
CODE_COVERAGE_MIN=85           # percentage
CODE_DUPLICATION_MAX=5         # percentage

# Image Optimization
IMAGE_COMPRESSION_TARGET=60    # percentage reduction
IMAGE_QUALITY_AUTO=best        # auto, best, 1-100

# ========================================
# SECURITY THRESHOLDS
# ========================================

# Vulnerability severity levels to alert
ALERT_ON_CRITICAL=true
ALERT_ON_HIGH=true
ALERT_ON_MEDIUM=false

# Require approval for
REQUIRE_APPROVAL_SECURITY=true
REQUIRE_APPROVAL_BREAKING=true
REQUIRE_APPROVAL_MAJOR_UI=true

# ========================================
# ACCESSIBILITY STANDARDS
# ========================================

# WCAG Level: A, AA, AAA
WCAG_LEVEL=AA

# Minimum accessibility score (0-100)
A11Y_SCORE_MIN=85

# ========================================
# OPTIONAL: THIRD-PARTY INTEGRATIONS
# ========================================

# Slack Integration (for notifications)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxxxx

# Discord Integration
DISCORD_WEBHOOK_URL=https://discordapp.com/api/webhooks/xxxxx

# Email Service (for alerts)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=admin@shield-sheep.io
SMTP_PASS=app_specific_password

# ========================================
# NOTES
# ========================================
# 
# 1. Never commit this file with real values
# 2. Use .env.local for local development (ignored by git)
# 3. Use GitHub Secrets for CI/CD
# 4. Rotate API keys regularly
# 5. Use strong, unique passwords for email/SMTP
# 6. Keep all secrets confidential
#
# ========================================
